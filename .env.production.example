# ════════════════════════════════════════════════════════════
# Variables de entorno para PRODUCCION en VPS
# Copia este archivo a .env y rellena los valores reales
# ════════════════════════════════════════════════════════════

# Base de datos (MySQL en contenedor)
DB_PASSWORD=cambiar_este_password_super_seguro
DB_NAME=sponsorship_mvp

# JWT — secreto largo y aleatorio
# Generalo con: openssl rand -hex 32
JWT_SECRET=cambiar_este_secreto_de_minimo_64_caracteres_aleatorios

# CORS — dominios desde donde se accede al API
# Si solo accedes por IP: http://45.88.191.29:3000
# Si tienes dominio: https://tudominio.com
CORS_ORIGINS=http://45.88.191.29:3000

# URL del API que ve el frontend
# Misma logica que CORS pero apuntando al API (puerto 8000)
NEXT_PUBLIC_API_URL=http://45.88.191.29:8000
